{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --script \"$CLAUDE_PROJECT_DIR/scripts/check_changed.py\"",
            "timeout": 60
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(make:*)",
      "Bash(pnpm:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "WebSearch"
    ]
  }
}
